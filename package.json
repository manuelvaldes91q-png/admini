{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && npm run build:server",
    "build:server": "esbuild server.ts --bundle --platform=node --format=esm --external:better-sqlite3 --external:vite --outfile=dist/server.js",
    "start": "NODE_ENV=production node dist/server.js",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "reset": "tsx reset.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "esbuild": "^0.28.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "node-routeros": "^1.6.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "source-map-support": "^0.5.21",
    "telegraf": "^4.16.3",
    "tsx": "^4.21.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
